[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/hud.gd" id="1"]

[node name="HUD" type="CanvasLayer"]
script = ExtResource("1")

; ── Barre de statuts horizontale (pleine largeur, haut de l'écran) ──
[node name="TopBar" type="PanelContainer" parent="."]
anchor_right = 1.0
offset_bottom = 50.0

; Layout Control — permet ancres indépendantes pour chaque zone
[node name="Layout" type="Control" parent="TopBar"]
layout_mode = 2

; ── Zone HP (gauche) — ancrée à gauche ──
[node name="HPZone" type="VBoxContainer" parent="TopBar/Layout"]
layout_mode = 1
anchor_left = 0.0
anchor_top = 0.0
anchor_right = 0.0
anchor_bottom = 1.0
offset_left = 8.0
offset_right = 250.0
alignment = 1
theme_override_constants/separation = 3

[node name="HPLabel" type="Label" parent="TopBar/Layout/HPZone"]
text = "❤  100 / 100"

[node name="HPBar" type="ProgressBar" parent="TopBar/Layout/HPZone"]
custom_minimum_size = Vector2(0, 18)
size_flags_horizontal = 3
max_value = 100.0
value = 100.0
show_percentage = false

; ── Zone Info centrale — pleine largeur, texte centré ──
[node name="InfoZone" type="VBoxContainer" parent="TopBar/Layout"]
layout_mode = 1
anchor_left = 0.0
anchor_top = 0.0
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2
alignment = 1
theme_override_constants/separation = 2

[node name="RoomLabel" type="Label" parent="TopBar/Layout/InfoZone"]
text = "Salle  1"
horizontal_alignment = 1

[node name="ScoreLabel" type="Label" parent="TopBar/Layout/InfoZone"]
text = "💰 Or : 0"
horizontal_alignment = 1

; ── Zone Armes (droite) — ancrée à droite, cartes ajoutées dynamiquement ──
[node name="WeaponRow" type="HBoxContainer" parent="TopBar/Layout"]
layout_mode = 1
anchor_left = 1.0
anchor_top = 0.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -420.0
offset_right = -6.0
alignment = 1
theme_override_constants/separation = 6

; ── Barre XP (bas de l'écran) ──
[node name="XPZone" type="MarginContainer" parent="."]
anchors_preset = 7
anchor_left = 0.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 10.0
offset_top = -52.0
offset_right = -10.0
offset_bottom = -6.0

[node name="VBox" type="VBoxContainer" parent="XPZone"]
layout_mode = 2

[node name="XPLabel" type="Label" parent="XPZone/VBox"]
text = "Niveau 1   —   0 / 80 XP"
horizontal_alignment = 1

[node name="XPBar" type="ProgressBar" parent="XPZone/VBox"]
custom_minimum_size = Vector2(0, 22)
size_flags_horizontal = 3
max_value = 80.0
value = 0.0
show_percentage = false

; ── Hint porte ──
[node name="DoorHint" type="Label" parent="."]
visible = false
anchors_preset = 8
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -220.0
offset_top = -90.0
offset_right = 220.0
offset_bottom = -62.0
text = "🚪  Salle vidée !  [ ESPACE ] pour continuer"
horizontal_alignment = 1

; ── Level Up (overlay plein écran) ──
[node name="LevelUp" type="Control" parent="."]
mouse_filter = 2
visible = false
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Overlay" type="ColorRect" parent="LevelUp"]
