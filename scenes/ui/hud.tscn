[node name="Subtitle" type="Label" parent="LevelUp/Panel/VBox"]
text = "Choisissez une amélioration"
horizontal_alignment = 1

[node name="Cards" type="HBoxContainer" parent="LevelUp/Panel/VBox"]
layout_mode = 2
alignment = 1

