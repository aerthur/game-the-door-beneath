; ── Boutons tactiles (mobile) — D-pad bas-droite ──
[node name="TouchButtons" type="Control" parent="."]
mouse_filter = 2
anchor_right = 1.0
anchor_bottom = 1.0

; Conteneur D-pad : croix 3×3 de 70px, ancrée bas-droite, au-dessus de la XPZone
[node name="DPad" type="Control" parent="TouchButtons"]
